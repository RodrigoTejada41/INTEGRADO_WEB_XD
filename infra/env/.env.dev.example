POSTGRES_DB=sync_central_dev
POSTGRES_USER=sync_user
POSTGRES_PASSWORD=change-dev-postgres-password

ADMIN_TOKEN=change-dev-admin-token
JWT_SECRET=change-dev-jwt-secret
CORS_ORIGINS=http://localhost:8080,http://localhost:3000

RETENTION_MONTHS=14
RETENTION_MODE=archive
RETENTION_JOB_ENABLED=true
RETENTION_JOB_INTERVAL_MINUTES=60
AUTO_CREATE_TABLES=true

BACKEND_LOG_LEVEL=DEBUG
FRONTEND_LOG_LEVEL=INFO
