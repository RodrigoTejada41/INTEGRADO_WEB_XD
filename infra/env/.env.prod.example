# Database
POSTGRES_DB=sync_central
POSTGRES_USER=sync_user
POSTGRES_PASSWORD=change-strong-postgres-password
SYNC_ADMIN_DB=sync_admin

# Backend security
ADMIN_TOKEN=change-strong-admin-token
JWT_SECRET=change-very-strong-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRES_MINUTES=30
JWT_REFRESH_EXPIRES_MINUTES=10080
CORS_ORIGINS=https://movisystecnologia.com.br

# Sync retention
RETENTION_MONTHS=14
RETENTION_MODE=archive
RETENTION_JOB_ENABLED=true
RETENTION_JOB_INTERVAL_MINUTES=60
AUTO_CREATE_TABLES=true

# Logs
BACKEND_LOG_LEVEL=INFO
FRONTEND_LOG_LEVEL=INFO

# HTTPS / domain
DOMAIN=
LETSENCRYPT_EMAIL=
ENABLE_WWW_DOMAIN=false

# Monitoring alerts
ALERT_WEBHOOK_URL=
DISK_ALERT_PERCENT=85
MEM_ALERT_PERCENT=90

# Backup retention
BACKUP_RETENTION_DAYS=14
