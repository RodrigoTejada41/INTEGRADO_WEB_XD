# Database
POSTGRES_DB=sync_central
POSTGRES_USER=sync_user
POSTGRES_PASSWORD=change-strong-postgres-password
SYNC_ADMIN_DB=sync_admin

# Backend security
ADMIN_TOKEN=change-strong-admin-token

# Sync retention
RETENTION_MONTHS=14
RETENTION_MODE=archive
RETENTION_JOB_ENABLED=true
RETENTION_JOB_INTERVAL_MINUTES=60
AUTO_CREATE_TABLES=true

# Sync Admin security
SYNC_ADMIN_SECRET_KEY=change-very-strong-secret-key
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=change-admin-password
INTEGRATION_API_KEY=change-integration-api-key
CONTROL_EMPRESA_ID=12345678000199
CONTROL_EMPRESA_NOME=Empresa XD

# Logs
BACKEND_LOG_LEVEL=INFO
FRONTEND_LOG_LEVEL=INFO

# HTTPS / domain
DOMAIN=
LETSENCRYPT_EMAIL=

# Monitoring alerts
ALERT_WEBHOOK_URL=
DISK_ALERT_PERCENT=85
MEM_ALERT_PERCENT=90

# Backup retention
BACKUP_RETENTION_DAYS=14
