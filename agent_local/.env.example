AGENT_EMPRESA_ID=12345678000199
AGENT_API_BASE_URL=https://movisystecnologia.com.br/admin/api
AGENT_API_KEY=
AGENT_PAIRING_CODE=
AGENT_DEVICE_LABEL=loja-01
# Opcional fallback se nao usar Windows Credential Manager.
AGENT_MANUAL_CONFIG_PASSWORD=
AGENT_MARIADB_URL=mysql+pymysql://root:root@127.0.0.1:3308/xd
AGENT_SOURCE_QUERY=SELECT SHA2(CONCAT(IFNULL(DocumentKeyId,''),'|',IFNULL(ItemKeyId,''),'|',DATE_FORMAT(COALESCE(CloseDate,CreationDate),'%Y-%m-%d %H:%i:%s')),256) AS uuid, :empresa_id AS empresa_id, COALESCE(ItemDescription,'SEM_DESCRICAO') AS produto, COALESCE(TotalAmount,0) AS valor, DATE(COALESCE(CloseDate,CreationDate)) AS data, COALESCE(CloseDate,CreationDate) AS data_atualizacao FROM salesdocumentsreportview WHERE COALESCE(CloseDate,CreationDate) > :since ORDER BY COALESCE(CloseDate,CreationDate) ASC LIMIT :limit
SYNC_INTERVAL_MINUTES=15
BATCH_SIZE=500
TIMEOUT_SECONDS=30
VERIFY_SSL=true
CHECKPOINT_FILE=agent_local/data/checkpoints.json
AGENT_API_KEY_FILE=agent_local/data/agent_api_key.txt
LOG_LEVEL=INFO
