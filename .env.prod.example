POSTGRES_DB=sync_central
POSTGRES_USER=sync_user
POSTGRES_PASSWORD=change-this-postgres-password

ADMIN_TOKEN=change-this-admin-token
BACKEND_SECRET_KEY=change-this-backend-secret
FRONTEND_SECRET_KEY=change-this-frontend-secret
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=change-this-admin-password
INTEGRATION_API_KEY=change-this-integration-api-key
ENVIRONMENT=production

LOG_LEVEL=INFO
APP_ENV=production
AUTO_CREATE_TABLES=false
RETENTION_MODE=archive
RETENTION_MONTHS=14
RETENTION_JOB_ENABLED=true
RETENTION_JOB_INTERVAL_MINUTES=60
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=120
CORS_ALLOWED_ORIGINS=https://app.example.com

CONTROL_EMPRESA_ID=12345678000199
CONTROL_EMPRESA_NOME=Empresa XD

# Opcional para futuro dominio HTTPS
SERVER_NAME=example.com
