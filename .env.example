# Primary processing source folder (project pipeline)
KNOWLEDGE_SOURCE_PATHS=E:\Projetos\ENGENHARIA_REVERSA\XDSoftware-Reverse-Engineering

# Optional external knowledge base (consultation only, not ingested)
KNOWLEDGE_REFERENCE_PATHS=E:\Projetos\CEREBRO_VIVO

# Local runtime paths
DB_PATH=output/system.db
OBSIDIAN_VAULT_PATH=obsidian-vault
NEXUS_MANIFEST_PATH=nexus-manifests
LOG_LEVEL=INFO

# API network
API_HOST=0.0.0.0
API_PORT=8080

# JWT and RBAC
JWT_SECRET=change-me-very-strong-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRES_MINUTES=60
JWT_REFRESH_EXPIRES_MINUTES=10080

# username:password:role (semicolon-separated)
# roles supported: admin, analyst, viewer
AUTH_USERS=admin:admin123:admin;analyst:analyst123:analyst;viewer:viewer123:viewer
